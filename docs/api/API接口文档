## 五、YonSuiteClient（Java 版 HTTP 调用）

使用 Hutool（你项目里已有）：

```java
@Service
@RequiredArgsConstructor
public class YonSuiteClient {

    private final YonAuthService authService;
    private final YonSuiteConfigService configService;

    private String buildBaseUrl(String tenantId) {
        YonSuiteTenantConfig cfg = configService.getByTenantId(tenantId);
        if (cfg == null) {
            throw new IllegalStateException("YonSuite config not found for tenant: " + tenantId);
        }
        return StrUtil.removeSuffix(cfg.getBaseUrl(), "/");
    }

    public JSONObject queryVoucherById(String tenantId, String voucherId) {
        String token = authService.getAccessToken(tenantId);
        String baseUrl = buildBaseUrl(tenantId);

        String url = baseUrl + "/yonbip/EFI/openapi/voucher/queryVoucherById"
                + "?access_token=" + URLEncoder.encode(token, StandardCharsets.UTF_8);

        JSONObject body = new JSONObject();
        body.putOnce("voucherId", voucherId);

        String respStr = HttpRequest.post(url)
                .header("Content-Type", "application/json")
                .body(body.toString())
                .timeout(10_000)
                .execute()
                .body();

        JSONObject resp = JSONUtil.parseObj(respStr);
        if (!"200".equals(resp.getStr("code"))) {
            throw new IllegalStateException("YonSuite queryVoucherById error: "
                    + resp.getStr("code") + " - " + resp.getStr("message"));
        }

        return resp.getJSONObject("data");
    }

    public ThirdLoginCodeResp getThirdLoginCode(
            String tenantId,
            ThirdLoginCodeReq req
    ) {
        String token = authService.getAccessToken(tenantId);
        String baseUrl = buildBaseUrl(tenantId);

        String url = baseUrl + "/yonbip/yht/getThirdLoginCode"
                + "?access_token=" + URLEncoder.encode(token, StandardCharsets.UTF_8);

        JSONObject body = new JSONObject();
        body.putOpt("thirdUcId", req.getThirdUcId());
        body.putOpt("userId", req.getUserId());
        body.putOpt("mobile", req.getMobile());
        body.putOpt("email", req.getEmail());
        body.putOpt("userName", req.getUserName());
        body.putOpt("userCode", req.getUserCode());

        String respStr = HttpRequest.post(url)
                .header("Content-Type", "application/json")
                .body(body.toString())
                .timeout(10_000)
                .execute()
                .body();

        JSONObject resp = JSONUtil.parseObj(respStr);
        if (!"200".equals(resp.getStr("code"))) {
            throw new IllegalStateException("YonSuite getThirdLoginCode error: "
                    + resp.getStr("code") + " - " + resp.getStr("message"));
        }

        JSONObject data = resp.getJSONObject("data");
        ThirdLoginCodeResp result = new ThirdLoginCodeResp();
        result.setStatus(data.getStr("status"));
        result.setCurYhtEnvironment(data.getStr("curYhtEnvironment"));
        result.setCode(data.getStr("code"));
        result.setBindYhtUser("true".equalsIgnoreCase(data.getStr("isBindYhtUser")));
        return result;
    }

    @Data
    public static class ThirdLoginCodeReq {
        private String thirdUcId;
        private String userId;
        private String mobile;
        private String email;
        private String userName;
        private String userCode;
    }

    @Data
    public static class ThirdLoginCodeResp {
        private String status;
        private String curYhtEnvironment;
        private String code;
        private boolean bindYhtUser;
    }
}
```

