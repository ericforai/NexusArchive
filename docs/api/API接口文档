## 四、YonAuthService（Java 版 token 管理）

```java
@Service
@RequiredArgsConstructor
public class YonAuthService {

    private final YonSuiteConfigService configService;

    // 简单本地缓存，避免每次查库（可选）
    private final ConcurrentHashMap<String, YonSuiteTenantConfig> cache = new ConcurrentHashMap<>();

    public String getAccessToken(String tenantId) {
        YonSuiteTenantConfig cfg = getConfig(tenantId);

        if (cfg.getAccessToken() != null && cfg.getAccessTokenExpiresAt() != null) {
            if (cfg.getAccessTokenExpiresAt().isAfter(LocalDateTime.now().plusSeconds(60))) {
                return cfg.getAccessToken();
            }
        }

        // TODO: 按“企业自建获取token”文档实现真正的获取逻辑
        TokenResponse tokenResp = callYonGetTokenApi(cfg);

        cfg.setAccessToken(tokenResp.getAccessToken());
        cfg.setAccessTokenExpiresAt(LocalDateTime.now().plusSeconds(tokenResp.getExpiresIn() - 60));

        configService.saveOrUpdate(cfg);
        cache.put(tenantId, cfg);

        return cfg.getAccessToken();
    }

    private YonSuiteTenantConfig getConfig(String tenantId) {
        YonSuiteTenantConfig cached = cache.get(tenantId);
        if (cached != null) {
            return cached;
        }
        YonSuiteTenantConfig cfg = configService.getByTenantId(tenantId);
        if (cfg == null) {
            throw new IllegalStateException("YonSuite config not found for tenant: " + tenantId);
        }
        cache.put(tenantId, cfg);
        return cfg;
    }

    private TokenResponse callYonGetTokenApi(YonSuiteTenantConfig cfg) {
        // TODO: 根据用友“企业自建获取token”官方文档实现
        // 使用 Hutool HttpRequest 或 Spring WebClient 均可
        throw new UnsupportedOperationException("callYonGetTokenApi not implemented");
    }

    @Data
    public static class TokenResponse {
        private String accessToken;
        private long expiresIn;
    }
}
