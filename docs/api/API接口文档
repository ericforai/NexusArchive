## 六、SSO 与凭证同步的 Service + Controller

### 1. 凭证同步 Service

```java
@Service
@RequiredArgsConstructor
public class YonVoucherSyncService {

    private final YonSuiteClient yonSuiteClient;
    private final YonVoucherMapper yonVoucherMapper;        // Yon JSON -> CanonicalVoucher
    private final CanonicalVoucherMapper canonicalMapper;   // MyBatis-Plus 持久化

    @Transactional
    public String syncByVoucherId(String tenantId, String voucherId) {
        JSONObject raw = yonSuiteClient.queryVoucherById(tenantId, voucherId);
        CanonicalVoucher voucher = yonVoucherMapper.fromYon(raw, tenantId);
        // upsert：根据 source_system + source_voucher_id
        canonicalMapper.upsertBySource(voucher);
        return voucher.getId();
    }
}
```

### 2. SSO Service

```java
@Service
@RequiredArgsConstructor
public class YonSsoService {

    private final YonSuiteClient yonSuiteClient;
    private final YonSuiteConfigService configService;

    public YonSsoDto getLoginCode(String tenantId, String userId,
                                  String mobile, String email,
                                  String userName, String userCode) {

        YonSuiteTenantConfig cfg = configService.getByTenantId(tenantId);
        if (cfg == null) {
            throw new IllegalStateException("YonSuite config not found for tenant: " + tenantId);
        }

        YonSuiteClient.ThirdLoginCodeReq req = new YonSuiteClient.ThirdLoginCodeReq();
        req.setThirdUcId(cfg.getThirdUcId());
        req.setUserId(userId);
        req.setMobile(mobile);
        req.setEmail(email);
        req.setUserName(userName);
        req.setUserCode(userCode);

        YonSuiteClient.ThirdLoginCodeResp resp =
                yonSuiteClient.getThirdLoginCode(tenantId, req);

        YonSsoDto dto = new YonSsoDto();
        dto.setCurYhtEnvironment(resp.getCurYhtEnvironment());
        dto.setLoginCode(resp.getCode());
        dto.setBound(resp.isBindYhtUser());
        return dto;
    }

    @Data
    public static class YonSsoDto {
        private String curYhtEnvironment;
        private String loginCode;
        private boolean bound;
    }
}
```

### 3. REST Controller（走 Spring Security + JWT）

```java
@RestController
@RequestMapping("/api/integration/yonsuite")
@RequiredArgsConstructor
public class YonSuiteIntegrationController {

    private final YonVoucherSyncService voucherSyncService;
    private final YonSsoService yonSsoService;

    @PostMapping("/vouchers/sync-by-id")
    @PreAuthorize("hasAuthority('yon:sync_voucher')")
    public ResponseEntity<?> syncVoucherById(@RequestBody SyncVoucherReq req) {
        String internalId = voucherSyncService.syncByVoucherId(req.getTenantId(), req.getVoucherId());
        return ResponseEntity.ok(Map.of(
                "voucher_id", internalId,
                "source_voucher_id", req.getVoucherId()
        ));
    }

    @PostMapping("/sso/get-login-code")
    @PreAuthorize("hasAuthority('yon:sso')")
    public ResponseEntity<?> getLoginCode(@RequestBody YonSsoReq req) {
        YonSsoService.YonSsoDto dto = yonSsoService.getLoginCode(
                req.getTenantId(),
                req.getUserId(),
                req.getMobile(),
                req.getEmail(),
                req.getUserName(),
                req.getUserCode()
        );
        return ResponseEntity.ok(dto);
    }

    @Data
    public static class SyncVoucherReq {
        private String tenantId;
        private String voucherId;
    }

    @Data
    public static class YonSsoReq {
        private String tenantId;
        private String userId;
        private String mobile;
        private String email;
        private String userName;
        private String userCode;
    }
}
```

