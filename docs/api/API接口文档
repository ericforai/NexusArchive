@Service
@RequiredArgsConstructor
public class YonSuiteConfigService {

    private final YonSuiteTenantConfigMapper mapper;

    public YonSuiteTenantConfig getByTenantId(String tenantId) {
        return mapper.selectOne(
                Wrappers.<YonSuiteTenantConfig>lambdaQuery()
                        .eq(YonSuiteTenantConfig::getTenantId, tenantId)
                        .last("limit 1")
        );
    }

    public void saveOrUpdate(YonSuiteTenantConfig config) {
        if (config.getId() == null) {
            mapper.insert(config);
        } else {
            config.setUpdatedAt(LocalDateTime.now());
            mapper.updateById(config);
        }
    }
}
