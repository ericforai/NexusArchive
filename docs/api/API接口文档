        {
          "file_name": "invoice_123.pdf",
          "file_url": "http://erp-internal/files/invoice_123.pdf", // 或 Base64
          "file_hash": "sm3:abc123...", // 来源端计算的哈希 (用于真实性校验)
          "file_type": "原始凭证"
        }
      ]
    }
