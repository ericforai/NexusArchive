# Input: 环境变量
# Output: 环境变量配置
# Pos: 环境配置
# 一旦我被更新，务必更新我的开头注释，以及所属的文件夹的 md。

# NexusArchive 开发环境变量配置
# 警告: 此文件包含敏感信息，请勿提交到版本控制！

# 用友 YonSuite 集成配置
YONSUITE_APP_KEY=96a95c00982446cba484ccc4936b221b
YONSUITE_APP_SECRET=e9a58fd35f3ca3f0a46d27b8859758b1ed35f0b6

# 数据库配置 (Docker Compose 映射端口)
DB_HOST=localhost
DB_PORT=54321
DB_NAME=nexusarchive
DB_USER=postgres
DB_PASSWORD=postgres

# Redis 配置 (Docker Compose 映射端口)
REDIS_HOST=localhost
REDIS_PORT=16379

# Temporary disable schema validation for migration
SCHEMA_VALIDATION_ENABLED=false
SPRING_FLYWAY_VALIDATE_ON_MIGRATE=false

# JWT 密钥路径
# 使用 classpath: 前缀，密钥文件位于 src/main/resources/keystore/
JWT_PUBLIC_KEY_LOCATION=classpath:keystore/jwt_public.pem
JWT_PRIVATE_KEY_LOCATION=classpath:keystore/jwt_private.pem

# SM4 国密加密密钥 (32位十六进制, 128-bit)
SM4_KEY=a1b2c3d4e5f67890a1b2c3d4e5f67890

# 审计日志 HMAC 密钥 (开发环境)
AUDIT_LOG_HMAC_KEY=dev_hmac_key_for_development_only

# 病毒扫描类型 (开发环境使用 mock)
VIRUS_SCAN_TYPE=mock

# 时间戳降级配置 (开发环境允许降级)
TIMESTAMP_FALLBACK=true
