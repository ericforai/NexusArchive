{
  "name": "nexusarchive---future-accounting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "seed": "npx tsx backend/src/scripts/seed_extended.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 npx playwright test tests/playwright/ui/smoke_core_paths.spec.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "check:arch": "depcruise src/",
    "check:arch:graph": "depcruise src/ --output-type dot | dot -T svg > arch-dependencies.svg"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tanstack/react-query": "^5.90.12",
    "@xyflow/react": "^12.9.3",
    "antd": "^6.1.1",
    "axios": "^1.13.2",
    "lucide-react": "^0.554.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.4.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "dependency-cruiser": "^17.3.5",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^4.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.15"
  }
}
