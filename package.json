{
  "name": "nexusarchive---future-accounting",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "seed": "npx tsx backend/src/scripts/seed_extended.ts",
    "dev": "bash scripts/dev.sh",
    "dev:vite": "vite",
    "dev:stop": "bash scripts/dev-stop.sh",
    "db:dump": "bash scripts/db-dump.sh",
    "db:load": "bash scripts/db-load.sh",
    "db:reset": "bash scripts/db-reset.sh",
    "verify:seq": "bash scripts/verify-sequence-check-is-called.sh",
    "deploy": "bash scripts/deploy.sh",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "self-check:matrix": "node scripts/system-self-check/generate-module-test-matrix.mjs",
    "self-check:run": "bash scripts/system-self-check/run-system-self-check.sh",
    "self-check:integration": "bash scripts/system-self-check/run-integration-gate.sh",
    "test:smoke": "PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=mac15-arm64 npx playwright test tests/playwright/ui/smoke_core_paths.spec.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx --max-warnings=0",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "complexity:check": "ESLINT_COMPLEXITY_MODE=1 eslint src --ext .ts,.tsx",
    "complexity:report": "bash scripts/complexity-report.sh",
    "check:arch": "depcruise src/",
    "check:arch:graph": "depcruise src/ --output-type dot | dot -T svg > arch-dependencies.svg",
    "modules:discover": "node scripts/discover-frontend-modules.js --discover",
    "modules:validate": "node scripts/discover-frontend-modules.js --validate",
    "modules:update": "node scripts/discover-frontend-modules.js --update-manifest",
    "prepare": "husky"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tanstack/react-query": "^5.90.12",
    "@types/d3-force": "^3.0.10",
    "@xyflow/react": "^12.9.3",
    "antd": "^6.1.1",
    "axios": "^1.13.2",
    "d3-force": "^3.0.0",
    "lucide-react": "^0.554.0",
    "pdfjs-dist": "^4.8.69",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-pdf": "^9.2.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.4.1",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.0.16",
    "dependency-cruiser": "^17.3.5",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^4.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.2",
    "vite": "^5.4.10",
    "vitest": "^4.0.15"
  },
  "overrides": {
    "zustand": "^5.0.9"
  },
  "postinstall": "husky"
}
