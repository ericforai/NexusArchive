# ==============================================================================
# NexusArchive 生产环境配置模板
# ==============================================================================
# 用法: cp .env.prod.example .env.prod
# 注意: .env.prod 已加入 .gitignore，不会被提交到 Git
# 更新日期: 2025-01-12
# ==============================================================================

# ========== 版本控制 ==========
# Docker 镜像标签
TAG=latest

# ========== 数据库配置 ==========
# 数据库主机（Docker Compose 中使用服务名）
DB_HOST=nexus-db
# 数据库端口（Docker 内部端口）
DB_PORT=5432
# 数据库名称
DB_NAME=nexusarchive
# 数据库用户名
DB_USER=postgres
# 数据库密码（必填，请使用强密码 ≥16 位）
# 生成方式: openssl rand -base64 16
DB_PASSWORD=your_secure_database_password_here

# ========== Redis 配置 ==========
# Redis 主机（Docker Compose 中使用服务名）
REDIS_HOST=nexus-redis
# Redis 端口（Docker 内部端口）
REDIS_PORT=6379
# Redis 密码（可选，建议生产环境启用）
REDIS_PASSWORD=

# ========== 安全配置 ==========
# SM4 国密加密密钥（32位十六进制字符串，必填）
# 生成方式: openssl rand -hex 16
SM4_KEY=your_32_char_hex_key_here

# 审计日志 HMAC 密钥（用于日志完整性校验）
# 生成方式: openssl rand -hex 32
AUDIT_LOG_HMAC_KEY=your_audit_log_hmac_key_here

# ========== 应用端口配置 ==========
# 后端 API 端口
SERVER_PORT=19090
# 前端 HTTP 端口
FRONTEND_PORT=80

# ========== Spring Profile ==========
# prod: 生产环境（PostgreSQL）
SPRING_PROFILES_ACTIVE=prod

# ========== CORS 配置 ==========
# 允许的跨域源（多个用逗号分隔，部署时替换为实际域名）
APP_SECURITY_CORS_ALLOWED_ORIGINS=https://your-domain.com

# ========== 病毒扫描配置 ==========
# 类型: mock（模拟扫描）| clamav（真实扫描，需要 ClamAV 服务器）
VIRUS_SCAN_TYPE=mock
# ClamAV 服务器地址（如果使用 clamav）
VIRUS_SCAN_HOST=localhost
VIRUS_SCAN_PORT=3310

# ========== 时间戳服务配置 ==========
# 时间戳服务是否启用
TIMESTAMP_ENABLED=false
# 时间戳服务不可用时是否降级
TIMESTAMP_FALLBACK=true

# ========== Schema 验证配置 ==========
# 是否启用 Entity-Database Schema 验证（生产建议开启）
SCHEMA_VALIDATION_ENABLED=true
# 发现不一致时是否阻止启动
SCHEMA_VALIDATION_FAIL=false

# ========== 调试配置 ==========
# 调试接口开关（生产环境必须禁用）
APP_DEBUG_ENABLED=false

# ========== YonSuite 集成（可选）==========
# YonSuite 基础 URL
YONSUITE_BASE_URL=https://dbox.yonyoucloud.com/iuap-api-gateway
# YonSuite App Key
YONSUITE_APP_KEY=
# YonSuite App Secret
YONSUITE_APP_SECRET=

# ========== 文件存储配置 ==========
# 归档文件存储路径
ARCHIVE_ROOT_PATH=/opt/nexusarchive/archives
# 临时文件存储路径
ARCHIVE_TEMP_PATH=/opt/nexusarchive/temp

# ========== SSL 证书配置 ==========
# Let's Encrypt 邮箱（用于证书申请提醒）
LETSENCRYPT_EMAIL=admin@your-domain.com

# ========== AI Integration（可选）==========
# GEMINI_API_KEY=
