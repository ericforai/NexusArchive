# 生产环境前端 Dockerfile
# 构建静态文件并用 Nginx 托管

# 阶段1: 构建
FROM node:18-alpine AS builder

WORKDIR /app

# 复制依赖文件
COPY package*.json ./

# 安装依赖
RUN npm ci --only=production=false

# 复制源码
COPY . .

# 构建生产版本
RUN npm run build

# 阶段2: 生产镜像
FROM nginx:alpine

# 复制构建产物到 Nginx
COPY --from=builder /app/dist /usr/share/nginx/html

# 复制 Nginx 配置
COPY nginx/nginx.prod.conf /etc/nginx/nginx.conf

# 暴露端口
EXPOSE 80 443

CMD ["nginx", "-g", "daemon off;"]
