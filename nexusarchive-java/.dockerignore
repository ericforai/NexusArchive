# ==============================================================================
# 后端 Docker 构建忽略规则
# ==============================================================================
#
# 目标：只复制必要文件到构建上下文
# 优化：减少传输时间，加速构建
# ==============================================================================

# Input: 版本控制/构建忽略规则
# Output: 忽略规则配置
# Pos: 仓库配置
# 一旦我被更新，务必更新我的开头注释，以及所属的文件夹的 md。

# 构建产物（会重新编译）
target/*
!target/*.jar

# IDE 和编辑器
.idea
.vscode
*.iml
*.swp
*.swo

# 系统文件
.DS_Store
Thumbs.db

# 日志
*.log

# Git
.git
.gitignore
.gitattributes

# 文档（不需要打包）
docs/
*.md
!README.md

# 其他
.keystore/
*.jks
*.p12
