# ============================================
# NexusArchive .gitignore
# 私有仓库优化版 - 最大化两台 Mac 之间的同步
# ============================================

# ----------------
# 必须忽略（运行时生成/太大/每台电脑不同）
# ----------------

# Node.js 依赖（太大，用 npm install 安装）
node_modules

# Java 编译产物（用 mvn 构建重新生成）
nexusarchive-java/target/

# 前端构建产物（用 npm run build 重新生成）
dist
dist-ssr
build
.cache

# 运行时 PID 文件（每次启动重新生成）
.run/

# 日志文件（运行时生成）
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# macOS 系统文件（每台电脑自动生成，内容不同）
.DS_Store

# 临时编辑器交换文件
*.sw?
*.suo

# ----------------
# 可选忽略（根据需要取消注释）
# ----------------

# IDE 配置（如果两台电脑用不同 IDE 配置则取消注释）
# .idea
# .vscode/*
# !.vscode/extensions.json

# ----------------
# 项目特定：构建发布包
# ----------------
*.tar.gz
nexusarchive-release.*

# ----------------
# 项目特定：测试/临时文件
# ----------------
test_aip*/
.m2-temp/
test_upload.pdf

# ----------------
# 项目特定：数据文件（如果太大或包含测试数据）
# ----------------
# 档案存储目录（如果包含大量测试文件）
# nexusarchive-java/data/

# 临时审批数据（如果需要同步则注释掉）
# pending_list.json
# temp_approvals.json

# 证书文件（如果需要同步则注释掉）
# *.pem

# ----------------
# 需要同步的重要文件（确保没有被忽略）
# ----------------
# .env                 ← 已移除忽略，会同步
# .env.local           ← 已移除忽略，会同步
# .env.example         ← 会同步（模板）
# .env.template        ← 会同步（模板）
# .idea/               ← 已移除忽略，会同步 IDE 配置
# .vscode/             ← 已移除忽略，会同步 IDE 配置
# scripts/             ← 会同步所有脚本
# docs/                ← 会同步所有文档

# Large Binaries
deploy/offline/bin/*.jar

