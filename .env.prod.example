# ========== NexusArchive 生产环境配置模板 ==========
# 复制此文件为 .env.prod 并填入实际值
# 注意：.env.prod 文件已加入 .gitignore，不会被提交到 Git

# ========== 版本控制 ==========
# Docker 镜像标签
TAG=latest

# ========== 数据库配置 ==========
# 数据库主机（Docker Compose 中使用服务名）
DB_HOST=nexus-db
# 数据库端口
DB_PORT=5432
# 数据库名称
DB_NAME=nexusarchive
# 数据库用户名
DB_USER=postgres
# 数据库密码（必填，请使用强密码）
DB_PASSWORD=your_secure_database_password_here

# ========== Redis 配置 ==========
# Redis 主机（Docker Compose 中使用服务名）
REDIS_HOST=nexus-redis
# Redis 端口
REDIS_PORT=6379

# ========== 安全配置 ==========
# SM4 加密密钥（32位十六进制字符串，必填）
# 生成方式: openssl rand -hex 16
SM4_KEY=your_32_char_hex_key_here

# JWT 签名密钥（≥32字符，必填）
# 生成方式: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_key_here

# 审计日志 HMAC 密钥（用于日志完整性校验）
# 生成方式: openssl rand -hex 16
AUDIT_LOG_HMAC_KEY=your_audit_log_hmac_key_here

# ========== 应用配置 ==========
# Spring 环境配置
SPRING_PROFILES_ACTIVE=prod

# CORS 允许的源（多个用逗号分隔）
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost,https://your-domain.com

# ========== 用友集成 ==========
# 用友 AppKey（如果使用用友集成）
YONSUITE_APP_KEY=your_yonsuite_app_key_here
# 用友 AppSecret（如果使用用友集成）
YONSUITE_APP_SECRET=your_yonsuite_app_secret_here

# ========== 病毒扫描配置 ==========
# 病毒扫描类型: mock | clamav
VIRUS_SCAN_TYPE=mock
# ClamAV 服务器地址（如果使用 ClamAV）
VIRUS_SCAN_HOST=localhost
# ClamAV 服务器端口
VIRUS_SCAN_PORT=3310

# ========== 其他配置 ==========
# Schema 验证是否启用
SCHEMA_VALIDATION_ENABLED=false
