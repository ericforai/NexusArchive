# Input: N/A
# Output: Host Mode 环境变量
# Pos: 根目录/Dev config
# 一旦我被更新，务必更新我的开头注释，以及所属的文件夹的 md。

# Host Mode Development Environment Variables
# Usage: set -a; source .env.host.dev; set +a

# Database Configuration (Connects to Docker on Host Port 54321)
DB_HOST=localhost
DB_PORT=54321
DB_NAME=nexusarchive
DB_USER=postgres
DB_PASSWORD=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:54321/nexusarchive

# Redis Configuration (Connects to Docker on Host Port 16379)
REDIS_HOST=localhost
REDIS_PORT=16379
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=16379

# Backend Server Port
SERVER_PORT=19090

# Security (Development Keys)
SM4_KEY=a1b2c3d4e5f67890a1b2c3d4e5f67890
JWT_PUBLIC_KEY_LOCATION=file:src/main/resources/keystore/jwt_public.pem
JWT_PRIVATE_KEY_LOCATION=file:src/main/resources/keystore/jwt_private.pem

# CORS
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:15175,http://127.0.0.1:15175
