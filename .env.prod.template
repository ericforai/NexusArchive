# ========== 版本控制 ==========
TAG=latest

# ========== 数据库配置 ==========
DB_HOST=nexus-db
DB_PORT=5432
DB_NAME=nexusarchive
DB_USER=postgres
DB_PASSWORD=改成你的安全密码

# ========== Redis 配置 ==========
REDIS_HOST=nexus-redis
REDIS_PORT=6379

# ========== 安全配置（必须修改）==========
# SM4 国密加密密钥（32位十六进制）
SM4_KEY=a1b2c3d4e5f67890a1b2c3d4e5f67890

# 审计日志 HMAC 密钥
AUDIT_LOG_HMAC_KEY=改成随机字符串

# 病毒扫描类型（skip=跳过, clamav=ClamAV）
VIRUS_SCAN_TYPE=skip

# 禁用时间戳降级
TIMESTAMP_FALLBACK=false

# Schema 验证
SCHEMA_VALIDATION_ENABLED=false

# ========== JWT 配置 ==========
JWT_PUBLIC_KEY_LOCATION=file:/app/keystore/jwt_public.pem
JWT_PRIVATE_KEY_LOCATION=file:/app/keystore/jwt_private.pem

# ========== 应用配置 ==========
SPRING_PROFILES_ACTIVE=prod
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost,https://www.digivoucher.cn,https://digivoucher.cn

# ========== 用友集成（可选）==========
YONSUITE_APP_KEY=
YONSUITE_APP_SECRET=
