#!/bin/sh
# husky pre-commit-complexity hook
# 复杂度检查：非阻塞警告模式，在提交前显示代码复杂度问题

# Input: Git 暂存区文件
# Output: 复杂度检查警告（不阻止提交）
# Pos: .husky/pre-commit-complexity

set -e

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${CYAN}📊 代码复杂度检查${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# 获取暂存区的文件
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)
STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.java$' || true)

FRONTEND_CHECKED=false
BACKEND_CHECKED=false

# ==============================================================================
# 前端复杂度检查 (TypeScript/React)
# ==============================================================================
if [ -n "$STAGED_TS_FILES" ]; then
  FRONTEND_CHECKED=true
  echo ""
  echo -e "${YELLOW}🔍 前端复杂度检查 (TypeScript/React)${NC}"
  echo -e "${CYAN}暂存区文件:${NC}"
  echo "$STAGED_TS_FILES" | while read -r file; do
    echo "  - $file"
  done

  # 运行 ESLint 复杂度检查（仅对有改动的文件）
  # 使用 || true 确保警告不会阻止提交
  echo ""
  npm run complexity:check 2>&1 | head -20 || true

  echo ""
  echo -e "${YELLOW}💡 提示: 运行 'npm run complexity:report' 查看完整报告${NC}"
fi

# ==============================================================================
# 后端复杂度检查 (Java)
# ==============================================================================
if [ -n "$STAGED_JAVA_FILES" ]; then
  BACKEND_CHECKED=true
  echo ""
  echo -e "${YELLOW}🔍 后端复杂度检查 (Java/Spring)${NC}"
  echo -e "${CYAN}暂存区文件:${NC}"
  echo "$STAGED_JAVA_FILES" | while read -r file; do
    echo "  - $file"
  done

  # 检查 ArchUnit 复杂度规则是否存在
  if [ -f "nexusarchive-java/pom.xml" ]; then
    # 运行后端复杂度检查（非阻塞）
    echo ""
    cd nexusarchive-java
    mvn test -Dtest=ComplexityRulesTest -q 2>&1 | head -20 || true
    cd ..
    echo ""
    echo -e "${YELLOW}💡 提示: 运行 'mvn test -Dtest=ComplexityRulesTest' 查看详细结果${NC}"
  fi
fi

# ==============================================================================
# 无相关文件时的提示
# ==============================================================================
if [ "$FRONTEND_CHECKED" = false ] && [ "$BACKEND_CHECKED" = false ]; then
  echo ""
  echo -e "${GREEN}✅ 无需检查: 暂存区中没有 .ts/.tsx/.java 文件${NC}"
fi

# ==============================================================================
# 总结
# ==============================================================================
echo ""
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}✅ 复杂度检查完成 (非阻塞模式)${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo ""
echo -e "${YELLOW}⚠️  复杂度警告不会阻止提交，但建议在提交前修复${NC}"
echo ""

# 始终返回成功，不阻止提交
exit 0
