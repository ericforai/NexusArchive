# NexusArchive 环境变量配置模板
# 复制此文件为 .env 或 .env.local，并根据实际环境填写

# ============================================================
# 🔐 必需配置（生产环境必须设置）
# ============================================================

# 数据库选择
# 可选值: dev (PostgreSQL开发), prod (PostgreSQL生产), prod-dameng (达梦), prod-kingbase (人大金仓)
SPRING_PROFILES_ACTIVE=dev

# 服务端口
SERVER_PORT=8080

# 数据库连接
# PostgreSQL 默认端口: 5432
# 达梦数据库默认端口: 5236
# 人大金仓默认端口: 54321
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexusarchive
DB_USER=postgres
DB_PASSWORD=your_strong_database_password

# JWT 密钥 (256位强密钥)
# ⚠️ 生产环境必须设置！不能使用默认值
# 建议使用以下命令生成: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-must-be-changed-in-production

# ============================================================
# 🔐 YonSuite 集成配置（如使用用友ERP）
# ============================================================

# YonSuite API 地址
YONSUITE_BASE_URL=https://dbox.yonyoucloud.com/iuap-api-gateway

# YonSuite 应用密钥
# ⚠️ 从用友开放平台获取，不要提交到版本控制
YONSUITE_APP_KEY=your_yonsuite_app_key
YONSUITE_APP_SECRET=your_yonsuite_app_secret

# ============================================================
# 🔐 Redis 配置（会话/缓存/Token黑名单）
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# 🔐 SM4 国密加密配置
# ============================================================

# SM4 加密密钥 (32位十六进制字符串)
# ⚠️ 生产环境必须修改！
# 建议使用以下命令生成: openssl rand -hex 16
SM4_KEY=0123456789abcdeffedcba9876543210

# ============================================================
# 📁 文件存储配置
# ============================================================

# 归档文件存储根路径
ARCHIVE_ROOT_PATH=/opt/nexusarchive/data/archives

# 临时文件路径
ARCHIVE_TEMP_PATH=/tmp/nexusarchive

# ============================================================
# 🔒 安全配置（可选）
# ============================================================

# 允许的跨域来源（多个用逗号分隔）
# 留空则允许所有来源（仅开发环境推荐）
CORS_ALLOWED_ORIGINS=

# ============================================================
# 📊 可选：Elasticsearch 配置（全文检索）
# ============================================================

ES_HOSTS=localhost:9200
ES_USERNAME=
ES_PASSWORD=

# ============================================================
# 📧 可选：邮件服务配置
# ============================================================

MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=

# ============================================================
# 🤖 可选：AI 集成
# ============================================================


# ============================================================
# 🦠 病毒扫描配置 (ClamAV)
# ============================================================

# 扫描模式: mock (开发默认) | clamav (生产推荐)
VIRUS_SCAN_TYPE=mock

# ClamAV 服务地址 (当 scan.type=clamav 时生效)
# 如果使用 Docker 部署，host 可设为容器名 nexusarchive-clamav
VIRUS_SCAN_HOST=localhost
VIRUS_SCAN_PORT=3310
