# ==============================================================================
# NexusArchive 环境配置模板
# ==============================================================================
# 使用方法:
#   本地开发: cp .env.example .env.local
#   服务器部署: cp .env.example .env.server
#
# 注意:
#   - .env.local 和 .env.server 已加入 .gitignore，不会提交到 Git
#   - 修改 .env.example 需要谨慎，会影响所有使用此模板的环境
# ==============================================================================

# ========== Spring Profile ==========
# dev: 开发环境
# prod: 生产环境
SPRING_PROFILES_ACTIVE=dev

# ========== 数据库配置 ==========
DB_HOST=localhost
DB_NAME=nexusarchive
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=54321                     # 本地开发端口（避免与本地 PostgreSQL 冲突）
                                 # 服务器部署可改为 5432

# ========== Redis 配置 ==========
REDIS_HOST=localhost
REDIS_PORT=16379                  # 本地开发端口（避免与本地 Redis 冲突）
                                 # 服务器部署内部使用 6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 应用端口 ==========
SERVER_PORT=19090                 # 后端 API 端口
FRONTEND_PORT=15175               # 前端开发服务器端口

# ========== 安全配置 ==========
# SM4 国密加密密钥（32位十六进制）
SM4_KEY=a1b2c3d4e5f67890a1b2c3d4e5f67890

# 审计日志 HMAC 密钥
AUDIT_LOG_HMAC_KEY=dev_hmac_key_for_development_only

# ========== Seed Data ==========
# 启动时自动导入 seed data（首次或数据为空时）
SEED_AUTO_IMPORT=true

# ========== CORS ==========
APP_SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:15175,http://127.0.0.1:15175

# ========== 病毒扫描配置 ==========
# mock: 模拟扫描（开发环境）
# clamav: ClamAV 扫描（需要 ClamAV 服务器）
VIRUS_SCAN_TYPE=mock

# ========== 时间戳服务配置 ==========
TIMESTAMP_FALLBACK=true           # 时间戳服务不可用时是否降级
TIMESTAMP_ENABLED=false
TIMESTAMP_AUTO_REQUEST=true

# ========== Schema 验证配置 ==========
SCHEMA_VALIDATION_ENABLED=false   # 是否启用 Entity-Database Schema 验证
SCHEMA_VALIDATION_FAIL=false      # 发现不一致时是否阻止启动

# ========== 用友 YonSuite 集成（可选）==========
YONSUITE_BASE_URL=https://dbox.yonyoucloud.com/iuap-api-gateway
YONSUITE_APP_KEY=
YONSUITE_APP_SECRET=

# ========== 文件存储 ==========
ARCHIVE_ROOT_PATH=./data/archives
ARCHIVE_TEMP_PATH=./data/temp

# ========== AI Integration（可选）==========
GEMINI_API_KEY=

# ========== Docker 镜像标签（服务器部署用）==========
TAG=latest
