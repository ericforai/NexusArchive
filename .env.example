# NexusArchive 环境变量配置示例
# 复制此文件为 .env 或 .env.local

# Environment Selection
# Options: dev, prod, prod-dameng, prod-kingbase
SPRING_PROFILES_ACTIVE=dev

# Server Configuration
SERVER_PORT=8080

# Database Configuration
# For Dev (PostgreSQL): Port 5432
# For Prod (Dameng): Port 5236
# For Prod (Kingbase): Port 54321
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexusarchive
DB_USER=postgres
DB_PASSWORD=postgres

# ============================================================
# 🔐 Security Configuration (MUST change in production!)
# ============================================================

# JWT Secret (256-bit key)
# Generate: openssl rand -base64 32
JWT_SECRET=your-256-bit-secret-key-change-this-in-production-environment

# SM4 Encryption Key (32 hex chars)
# Generate: openssl rand -hex 16
SM4_KEY=0123456789abcdeffedcba9876543210

# CORS Allowed Origins (comma-separated, leave empty for dev)
CORS_ALLOWED_ORIGINS=

# ============================================================
# 🔐 YonSuite Integration (if using)
# ============================================================

YONSUITE_BASE_URL=https://dbox.yonyoucloud.com/iuap-api-gateway
YONSUITE_APP_KEY=your_yonsuite_app_key
YONSUITE_APP_SECRET=your_yonsuite_app_secret

# ============================================================
# Redis Configuration
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================
# File Storage
# ============================================================

ARCHIVE_ROOT_PATH=./data/archives
ARCHIVE_TEMP_PATH=/tmp/nexusarchive

# ============================================================
# AI Integration (Optional)
# ============================================================

GEMINI_API_KEY=your_gemini_api_key_here

